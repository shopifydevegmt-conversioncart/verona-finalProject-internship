    "custom_liquid_BCTxT9": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "custom_liquid": "{%-liquid \n  assign demos = pages['demos'].metafields.home.menu.value | default: pages['demo'].metafields.home.menu.value\n  assign demo_size = demos.count | plus: 0\n  if demo_size < 1\n    continue\n  endif\n-%}\n<style>\n  html:has(#drawer-demo-themes:checked){\n    overflow: hidden;\n    padding-inline-end: var(--scrollbar-w);\n  }\n  .hdt-demoo-container {\n    --container-w: min(700px,70vw);\n    --spacing-x: 20px;\n    --spacing-y: 20px;\n    z-index: 9999;\n    position: relative;\n    .backdrop{\n      position:fixed;\n      inset: 0;\n      width:100%;\n      height:100%;\n      background-color: rgb(0 0 0 / 0.3);\n      content: \"\";\n      cursor: var(--cursor-close-svg-url) 28 28,auto;\n      opacity: 0;\n      content-visibility: hidden;\n      pointer-events: none;\n    }\n  \n    &:has(#drawer-demo-themes:checked){\n      .backdrop{\n        opacity: 1;\n        content-visibility: visible;\n        pointer-events: auto;\n      }\n      .hdt-demoo-buy-theme{\n        right: var(--container-w);\n        .hdt-demoos-btn{\n          .hdt-demoo-close-icon{\n            transform: translateY(0);\n            opacity: 1;\n          }\n        }\n        .hdt-demoos-count{\n          opacity: 0;\n          pointer-events: none;\n          transform: translateY(-15px);\n        }\n      }\n      .hdt-demoo-wrap{\n        transform: translateX(0);\n        opacity: 1;\n      }\n    }\n    .hdt-demoo-wrap{\n      max-width: var(--container-w);\n      position: fixed;\n      right: 0;\n      transition: 0.3s ease-in-out;\n      z-index: 999;\n      top: 0;\n      bottom: 0;\n      overflow-y: auto;\n      background-color: #fafafa;\n      color: #000;\n      padding: 40px 20px;\n      transform: translateX(100%);\n      opacity: 0;\n      @media (750px < width < 1300px){\n        padding: 40px 20px 80px;\n      }\n    }\n    .hdt-demoo-header{\n      margin-bottom: 30px;\n      h3{ \n        font-size: clamp(28px, 4vw, 40px);\n        font-weight: 600;\n        span {\n          font-size: clamp(16px, 2vw, 24px);\n        }\n      }\n    }\n    .hdt-demoo-item{\n      .hdt-demoo-wrap-title{\n        margin-top: 15px;\n      }\n      .hdt-demoo-item-image{\n        transition: .3s ;\n        box-shadow: 3px 5px 25px 0 rgba(0,0,0,.1);\n        &:hover{\n          box-shadow: 3px 5px 35px 0 rgba(0,0,0,.15);\n          transform: translateY(-5px);\n        }\n      }\n    }\n    .hdt-demoo-buy-theme{\n      position: fixed;\n      right: 0;\n      transition: 0.3s ease-in-out;\n      z-index: 1;\n      top: 0;\n      bottom: 0;\n      height: 100%;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      gap: 20px;\n    }\n    .hdt-demoos-btn {\n      pointer-events: auto;\n      a&{\n        .hdt-demoos-count{\n          gap: 5px;\n        }\n      }\n      &.hdt-purschase-btn{\n        .hdt-btn-wrappp{\n          background: #f21e4e;\n          color: #fff;\n        }\n      }\n      .hdt-btn-wrappp{\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        padding: 10px 20px;\n        min-width: 150px;\n        color: #000;\n        background: #fafafa;\n        position: relative;\n        min-height: 44px;\n        font-size: clamp(14px, 2vw, 18px);\n        box-shadow: 0 0 10px 1px rgba(0, 0, 0, 0.1);\n        overflow: hidden;\n        &:hover{\n          box-shadow: 0 0 10px 1px rgba(0, 0, 0, 0.2);\n        }\n      }\n      .hdt-demoos-count{\n        white-space: nowrap;\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        transition: 0.2s ease-in-out;\n        opacity: 1;\n        position: absolute;\n        left: 0;\n        top: 0;\n        height: 100%;\n        width: fit-content;\n        right: 0;\n        bottom: 0;\n        margin: 0 auto;\n        transition-delay: 0.5s;\n      }\n      .hdt-demoos-num{\n        font-weight: 600;\n      }\n      .hdt-demoo-close-icon{\n        position: absolute;\n        left: 0;\n        top: 0;\n        height: 100%;\n        width: 100%;\n        transition: 0.2s ease-in-out;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        opacity: 0;\n        transform: translateY(15px);\n        transition-delay: 0.5s;\n      }\n    }\n  }\n  @keyframes dmoo-count {\n    0%{\n      opacity: 1;\n      \n    }\n    100%{\n      opacity: 0;\n      width: 0;\n      opacity: 0;\n    }\n  }\n  \n</style>\n<div class=\"hdt-demoo-container hdt-hidden md:hdt-block\">\n  <div class=\"backdrop\" onclick=\"document.getElementById('drawer-demo-themes').checked = false;\"></div>\n  <div class=\"hdt-demoo-buy-theme hdt-pe-none\">\n    <label for=\"drawer-demo-themes\" class=\"hdt-demoos-btn\" aria-controls=\"drawer-demo-themes\" aria-label=\"Open demo themes\">\n      <div class=\"hdt-btn-wrappp\">\n        <div class=\"hdt-demoos-count\">\n          <div class=\"hdt-demoos-num\">{{ demo_size }}+</div>\n          <span style=\"width:3px\"></span>\n          <span class=\"hdt-demoos-label\">demos</span>\n        </div>\n        <div class=\"hdt-demoo-close-icon\">\n          Close\n        </div>\n      </div>\n    </label>\n    <a href=\"https://1.envato.market/nL6xBa\" target=\"_blank\" class=\"hdt-demoos-btn hdt-purschase-btn\">\n      <div class=\"hdt-btn-wrappp\">\n        <div class=\"hdt-demoos-count\">\n          <div class=\"hdt-icon-plus\">\n            <svg x=\"0px\" y=\"0px\" width=\"16px\" height=\"20px\" viewBox=\"0 0 16 20\" enable-background=\"new 0 0 16 20\" xml:space=\"preserve\">\n              <path fill=\"currentColor\" d=\"M16.097,5.831v12.751c0,0.232-0.084,0.434-0.251,0.602c-0.168,0.17-0.368,0.254-0.601,0.254H1.852\n                c-0.231,0-0.433-0.084-0.601-0.254C1.083,19.016,1,18.814,1,18.582V5.87c0-0.259,0.083-0.473,0.251-0.642\n                C1.419,5.06,1.62,4.976,1.852,4.976H4.02V4.587c0-1.269,0.445-2.352,1.335-3.246C6.245,0.447,7.296,0,8.51,0h0.077\n                c1.213,0,2.265,0.447,3.155,1.341s1.336,1.977,1.336,3.246v0.389h2.167c0.232,0,0.426,0.078,0.581,0.233\n                C16.007,5.391,16.097,5.598,16.097,5.831L16.097,5.831z M14.355,6.686h-1.277v1.478c0,0.259-0.084,0.473-0.252,0.641\n                c-0.168,0.169-0.368,0.253-0.6,0.253c-0.259,0-0.472-0.084-0.64-0.253c-0.168-0.168-0.251-0.382-0.251-0.641V6.686H5.761v1.478\n                c0,0.259-0.084,0.473-0.251,0.641C5.342,8.974,5.129,9.058,4.871,9.058c-0.232,0-0.433-0.084-0.601-0.253\n                C4.103,8.637,4.02,8.423,4.02,8.164V6.686H2.742v11.041h11.613V6.686z M5.761,4.976h5.575V4.587c0-0.803-0.271-1.483-0.813-2.041\n                C9.98,1.989,9.336,1.71,8.587,1.71H8.51c-0.749,0-1.394,0.279-1.936,0.836C6.032,3.104,5.761,3.784,5.761,4.587V4.976z\"></path>\n              </svg>\n          </div>\n          <span class=\"hdt-demoos-label\">Buy now</span>\n        </div>\n        <div class=\"hdt-demoo-close-icon\">\n          Buy now\n        </div>\n      </div>\n    </a>\n  </div>\n  <input type=\"checkbox\" class=\"hdt-hidden\" id=\"drawer-demo-themes\">\n  <div class=\"hdt-demoo-wrap\">\n    <div class=\"hdt-demoo-inner\">\n      <div class=\"hdt-demoo-header\">\n        <h3 class=\"hdt-text-center\">{{ demo_size }} <span>demos</span></h3>\n        <p class=\"hdt-text-center hdt-body-base\">Can't decide on one demo? Features from different demos can be<br class=\"hdt-hidden md:hdt-block\"> combined! Start creating your website</p>\n      </div>\n      <div class=\"hdt-demoo-grid hdt-row-grid hdt-grid-cols-1 md:hdt-grid-cols-2 lg:hdt-grid-cols-3\">\n        {%- for demo in demos -%}\n          {% liquid\n            assign image = demo.image \n            assign labels = demo.label\n            assign url = demo.url.value.url\n            assign name = demo.name\n          %}\n          <div class=\"hdt-demoo-item\">\n            <a href=\"{{ url }}\" class=\"hdt-demoo-inner\">\n              <div class=\"hdt-demoo-item-image\">\n                {%- if image != blank -%}\n                  {{ image | image_url: width: image.width, height: image.height | image_tag: loading: 'lazy', width: image.width, widths:'100,200,300,400,500,600,700,800,900,1000,1200,1400',\n                    loading: 'lazy', sizes: '', class: 'hdt-object-cover hdt-obj-eff' }}\n                {%- endif -%}\n              </div>\n              <div class=\"hdt-demoo-wrap-title hdt-flex hdt-justify-between hdt-align-center\">\n                <div class=\"hdt-demoo-item-title\">{{ name }}</div>\n                <div class=\"hdt-demo-label hdt-flex\">\n                  {%- for label in labels.value -%}\n                    <span class=\"hdt-demo_{{ label | handle }} hdt-flex hdt-align-center hdt-justify-center hdt-text-xs hdt-font-medium\">{{ label }}</span>\n                  {%- endfor -%}\n                </div>\n              </div>\n            </a>\n          </div>\n        {%- endfor -%}\n      </div>\n  \n    </div>\n  </div>\n</div>",
