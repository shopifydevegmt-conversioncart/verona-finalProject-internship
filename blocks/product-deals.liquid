<style>
  #{{ block.id }} {
    --space-bottom: {{ block.settings.space_bottom }}px;
    --countdown-content-color: {{ block.settings.countdown_content_color }};
    --countdown-background-color: {{ block.settings.countdown_background_color }};
    legend.hdt-text-{{ block.settings.alignment }}{
      text-align: {{ block.settings.alignment }};
      --alignment: {{ block.settings.alignment }};
      --alignment-mb: {{ block.settings.alignment_mb }};
    }
  }
</style>
{{ 'product-deals.css' | asset_url | stylesheet_tag }}
<fieldset id="{{ block.id }}" class="hdt-product-deals box-layout-{{ block.settings.box_layout }} layout-{{ block.settings.layout }} show-border-{{ block.settings.show_border }} {{ block.settings.rounded }} hdt-oh" {%- if block.settings.colors_by_block %} color-scheme="{{ block.settings.color_scheme }}"{% endif %} {{ block.shopify_attributes }}>
  <legend class="hdt-text-{{ block.settings.alignment }}">
    <div class="hdt-title__wrap">
      {% content_for 'block', type: 'heading', id: 'deals-title' %}
      {%- if block.settings.countdown_text != blank and block.settings.date_countdown != blank -%}
        <div class="hdt-countdown-wrap hdt-inline-flex hdt-align-center hdt-justify-center">
          <span class="hdt-countdown-text">{{ block.settings.countdown_text }}</span>
          {%- if block.settings.layout == '3' -%}
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="feather feather-clock"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          {%- endif -%}
          {% render 'countdown', countdown: block.settings.date_countdown %}
        </div>
      {%- endif -%}
    </div>
  </legend>
  <div class="hdt-product-carousel">
    <hdt-slider id="Slider-{{ block.id }}" class="hdt-slider-center-{{ block.settings.hdt_slide_center }} hdt-collection-has-pr1 hdt-collection-products hdt-slider__products  hdt-slider hdt-slider-parent hdt-slide-spacing-{{ block.settings.space_items }} hdt-relative {% if block.settings.navUI %}hdt-slider-has-nav{% endif %} {% if block.settings.dotUI %}hdt-slider-has-dots-dk{% endif %} lg:hdt-slides-{{ block.settings.col_dk | default: "auto" }} md:hdt-slides-{{ block.settings.col_tb | default: "auto" }} hdt-slides-{{ block.settings.col_mb | default: "auto" }}" config='{ "id": "Slider-{{ block.id }}", "navUI": {{ block.settings.navUI }}, "dotUI": true, "loop": {{ block.settings.loop }}, "autoPlay": {{ block.settings.autoplay | times: 1000 }}, "pauseOnHover": {{ block.settings.pauseOnHover }}, "navUICenter": true{% if block.settings.hdt_slide_center %}, "containScroll": "trimSnaps", "align": "center"{% endif %}, "active": {% if block.settings.box_layout == 'carousel' %}true{% else %}false{% endif %} }'>
      <div class="hdt-slider__viewport hdt-relative">
        <div class="hdt-slider__container"{% if block.settings.box_layout == 'grid' %} style="flex-wrap: wrap;"{% endif %}>
          {%- liquid 
            if block.settings.product_list != blank
              for product in block.settings.product_list limit: block.settings.products_count
                content_for 'block', type: '_deals_product', id: 'product-deals-product', closest.product: product, class_wrapper: "hdt-slider__slide"
              endfor
            else
              for i in (1..block.settings.products_count)
                capture current
                cycle 1, 2 , 3, 4
                endcapture
                  assign placeholder_image = 'product-apparel-' | append: current
                  render 'card-product-placeholder', image_ratio: block.settings.image_ratio, placeholder_image: placeholder_image, section_id: section.id, class: "hdt-slider__slide hdt-ratio--square hdt-text-start"
              endfor
            endif
          -%}
        </div>
      </div>
      {%- if block.settings.navUI -%}
        <div class="hdt-navigation hdt-position-{{ block.settings.nav_position }} hdt-visible-{{ block.settings.nav_visible }} hdt-style-{{ block.settings.nav_style }} hdt-shape-{{ block.settings.nav_shape }} hdt-size-{{ block.settings.nav_size }} hdt-hide-mobile-{{ block.settings.nav_hide_mobile }}">
          <button aria-controls="Slider-{{ block.id }}" class="hdt-slider__button hdt-slider__button--prev" type="button" disabled name="previous" aria-label="previous">
            <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M5.5 11L0 5.5L5.5 0L6.47625 0.97625L1.9525 5.5L6.47625 10.0238L5.5 11Z" fill="currentColor"/></svg>
          </button>
          <button aria-controls="Slider-{{ block.id }}" class="hdt-slider__button hdt-slider__button--next" type="button" disabled name="next" aria-label="next">
            <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M1.5 11L7 5.5L1.5 0L0.52375 0.97625L5.0475 5.5L0.52375 10.0238L1.5 11Z" fill="currentColor"/></svg>
          </button>
        </div>
      {%- endif -%}
      {%- if block.settings.dotUI -%}
        <div hdt-slider-dots aria-controls="Slider-{{ block.id }}" class="hdt-slider__dots hdt-pagination hdt-style-{{ block.settings.pag_style }} hdt-radius-{{ block.settings.pag_rounded }}{% if block.settings.only_show_mobile %} hdt-only-show-mobile{% else %} hdt-hide-mobile-{{ block.settings.pag_hide_mobile }}{% endif %}" style="--space-between: {{ block.settings.pag_space }}px; --margin-top: {{ block.settings.pag_mgt }}px;" hdt-reveal="slide-in" timeline></div>
      {%- endif -%}
    </hdt-slider>
  </div>
</fieldset>
{% schema %}
  {
    "name": "Product deals",
    "tag": null,
    "settings": [
      {
        "type": "header",
        "content": "Layout options"
      },
      {
        "type": "checkbox",
        "id": "colors_by_block",
        "label": "t:sections.all.colors.display_colors_by_block"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.all.colors.label",
        "visible_if": "{{ block.settings.colors_by_block == true }}"
      },
      {
        "type": "header",
        "content": "Heading options",
      },
      {
        "type": "select",
        "id": "layout",
        "label": "Layout",
        "visible_if": "{{ block.settings.date_countdown != blank }}",
        "options": [
          {
            "value": "1",
            "label": "Layout 1"
          },
          {
            "value": "2",
            "label": "Layout 2"
          },
          {
            "value": "3",
            "label": "Layout 3"
          }
        ],
        "default": "1",
      },
      {
        "type": "checkbox",
        "id": "show_border",
        "label": "Show border",
        "default": false,
      },    
      {
        "type": "select",
        "id": "rounded",
        "label": "t:blocks.column.settings.rounded.label",
        "options": [
          {
            "value": "none",
            "label": "t:none"
          },
          {
            "value": "hdt-radius-xs",
            "label": "t:blocks.column.settings.rounded.options.xs"
          },
          {
            "value": "hdt-radius-sm",
            "label": "t:blocks.column.settings.rounded.options.sm"
          },
          {
            "value": "hdt-radius",
            "label": "t:blocks.column.settings.rounded.options.medium"
          },
          {
            "value": "hdt-radius-lg",
            "label": "t:blocks.column.settings.rounded.options.large"
          },
          {
            "value": "hdt-radius-full",
            "label": "t:blocks.column.settings.rounded.options.full"
          }
        ],
        "default": "none",
        "visible_if": "{{ block.settings.show_border }}"
      },
      {
        "type": "text_alignment",
        "id": "alignment",
        "label": "t:blocks.column.settings.alignment.label",
        "default": "center"
      },
      {
        "type": "text_alignment",
        "id": "alignment_mb",
        "label": "t:blocks.column.settings.alignment.label_mb",
        "default": "center"
      },
      {
        "type": "paragraph",
        "content": "===== Countdown options =====",
      },
      {
        "type": "text",
        "id": "countdown_text",
        "label": "Countdown text",
      },
      {
        "type": "text",
        "id": "date_countdown",
        "label": "Date countdown",
        "info": "Countdown to the end sale date will be shown.",
        "placeholder": "YYYY-MM-DD"
      },
      {
        "type": "color",
        "id": "countdown_content_color",
        "label": "Countdown content color",
        "default": "#fff",
        "alpha": true,
      },
      {
        "type": "color",
        "id": "countdown_background_color",
        "label": "Countdown background color",
        "default": "#e4573d",
        "alpha": true,
      },
      {
        "type": "number",
        "id": "space_bottom",
        "label": "Space bottom",
        "default": 30
      },
      {
        "type": "header",
        "content": "General options",
      },  
      {
        "type": "product_list",
        "id": "product_list",
        "label": "Products list",
      },
      {
        "type": "range",
        "id": "products_count",
        "min": 1,
        "max": 50,
        "step": 1,
        "label": "t:sections.all.limit",
        "default": 8
      },
      {
        "type": "select",
        "id": "col_dk",
        "label": "t:sections.all.items_row.desktop",
        "default": "4",
        "options": [
          {
            "label": "1",
            "value": "1"
          },
          {
            "label": "2",
            "value": "2"
          },
          {
            "label": "3",
            "value": "3"
          },
          {
            "label": "4",
            "value": "4"
          },
          {
            "label": "5",
            "value": "5"
          },
          {
            "label": "6",
            "value": "6"
          }
        ]
      },
      {
        "type": "select",
        "id": "col_tb",
        "label": "t:sections.all.items_row.tablet",
        "default": "3",
        "options": [
          {
            "label": "1",
            "value": "1"
          },
          {
            "label": "2",
            "value": "2"
          },
          {
            "label": "3",
            "value": "3"
          },
          {
            "label": "4",
            "value": "4"
          }
        ]
      },
      {
        "type": "select",
        "id": "col_mb",
        "label": "t:sections.all.items_row.mobile",
        "default": "2",
        "options": [
          {
            "label": "1",
            "value": "1"
          },
          {
            "label": "2",
            "value": "2"
          }
        ]
      },
      {
        "type": "select",
        "id": "space_items",
        "label": "t:sections.all.space_items.desktop",
        "default": "x",
        "options": [
          {
            "label": "t:sections.all.space_items.default",
            "value": "x"
          },
          {
            "label": "0",
            "value": "0"
          },
          {
            "label": "5px",
            "value": "5"
          },
          {
            "label": "10px",
            "value": "10"
          },
          {
            "label": "20px",
            "value": "20"
          }
        ]
      },
      {
        "type": "header",
        "content": "Box layout"
      },
      {
        "type": "select",
        "id": "box_layout",
        "label": "layout design",
        "options": [
          {
            "value": "grid",
            "label": "Grid"
          },
          {
            "value": "carousel",
            "label": "Carousel"
          }
        ],
        "default": "grid"
      },
      {
        "type": "header",
        "content": "t:blocks.carousel.name",
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "hdt_slide_center",
        "label": "Show slide center",
        "default": false,
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "loop",
        "label": "t:blocks.carousel.settings.loop",
        "default": false,
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "range",
        "id": "autoplay",
        "min": 0,
        "max": 7,
        "step": 0.5,
        "unit": "s",
        "label": "t:blocks.carousel.settings.autoplay.label",
        "default": 0,
        "info": "t:blocks.carousel.settings.autoplay.info",
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "pauseOnHover",
        "label": "t:blocks.carousel.settings.autoplay.pause_on_hover",
        "default": false,
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "header",
        "content": "t:blocks.carousel.settings.navigation.label",
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "navUI",
        "label": "t:blocks.carousel.settings.navigation.use_navigation",
        "default": false,
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "select",
        "id": "nav_position",
        "label": "t:blocks.carousel.settings.navigation.position.label",
        "options": [
          {
            "value": "default",
            "label": "t:default"
          },
          {
            "value": "on_border",
            "label": "t:blocks.carousel.settings.navigation.position.options.on_border"
          },
          /*{
            "value": "out_side",
            "label": "Out side"
          } */
        ],
        "default": "default",
        "visible_if": "{{ block.settings.navUI and section.settings.show_on_title != true and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "select",
        "id": "nav_visible",
        "label": "t:blocks.carousel.settings.navigation.nav_visible.label",
        "options": [
          {
            "value": "always",
            "label": "t:blocks.carousel.settings.navigation.nav_visible.options.always"
          },
          {
            "value": "hover",
            "label": "t:blocks.carousel.settings.navigation.nav_visible.options.hover"
          }
        ],
        "default": "always",
        "visible_if": "{{ block.settings.navUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "select",
        "id": "nav_style",
        "label": "t:blocks.carousel.settings.navigation.nav_style.label",
        "options": [
          {
            "value": "default",
            "label": "t:default"
          },
          {
            "value": "outline",
            "label": "t:blocks.carousel.settings.navigation.nav_style.options.outline"
          },
          {
            "value": "simple",
            "label": "t:blocks.carousel.settings.navigation.nav_style.options.simple"
          }
        ],
        "default": "default",
        "visible_if": "{{ block.settings.navUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "select",
        "id": "nav_shape",
        "label": "t:blocks.carousel.settings.navigation.nav_shape.label",
        "options": [
          {
            "value": "default",
            "label": "t:default"
          },
          {
            "value": "rounded",
            "label": "t:blocks.carousel.settings.navigation.nav_shape.options.rounded"
          },
          {
            "value": "rotate",
            "label": "t:blocks.carousel.settings.navigation.nav_shape.options.rotate"
          }
        ],
        "default": "default",
        "info": "t:blocks.carousel.settings.navigation.nav_shape.info",
        "visible_if": "{{ block.settings.navUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "select",
        "id": "nav_size",
        "label": "t:blocks.carousel.settings.navigation.nav_size.label",
        "options": [
          {
            "value": "small",
            "label": "t:blocks.carousel.settings.navigation.nav_size.options.small"
          },
          {
            "value": "medium",
            "label": "t:blocks.carousel.settings.navigation.nav_size.options.medium"
          },
          {
            "value": "large",
            "label": "t:blocks.carousel.settings.navigation.nav_size.options.large"
          }
        ],
        "default": "small",
        "visible_if": "{{ block.settings.navUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "nav_hide_mobile",
        "label": "t:blocks.carousel.settings.navigation.nav_hide_mobile.label",
        "default": false,
        "visible_if": "{{ block.settings.navUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "header",
        "content": "t:blocks.carousel.settings.pagination.label",
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "dotUI",
        "label": "t:blocks.carousel.settings.pagination.use_pagination",
        "default": false,
        "visible_if": "{{ block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "select",
        "id": "pag_style",
        "label": "t:blocks.carousel.settings.pagination.style.label",
        "options": [
          {
            "value": "default",
            "label": "t:default"
          },
          {
            "value": "outline",
            "label": "t:blocks.carousel.settings.pagination.style.options.outline"
          },
          {
            "value": "elessi",
            "label": "t:blocks.carousel.settings.pagination.style.options.elessi"
          },
          {
            "value": "full",
            "label": "t:blocks.carousel.settings.pagination.style.options.full"
          },
          {
            "value": "number",
            "label": "t:blocks.carousel.settings.pagination.style.options.number"
          }
        ],
        "default": "default",
        "visible_if": "{{ block.settings.dotUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "pag_rounded",
        "label": "t:blocks.carousel.settings.pagination.rounded",
        "default": true,
        "visible_if": "{{ block.settings.dotUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "range",
        "id": "pag_space",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "t:blocks.carousel.settings.pagination.space",
        "default": 10,
        "visible_if": "{{ block.settings.dotUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "range",
        "id": "pag_mgt",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:blocks.carousel.settings.pagination.space_between_pagination",
        "default": 10,
        "visible_if": "{{ block.settings.dotUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "only_show_mobile",
        "label": "t:blocks.carousel.settings.pagination.only_show_mobile",
        "default": false,
        "visible_if": "{{ block.settings.dotUI and block.settings.box_layout == 'carousel' }}"
      },
      {
        "type": "checkbox",
        "id": "pag_hide_mobile",
        "label": "t:blocks.carousel.settings.pagination.pag_hide_mobile",
        "default": false,
        "visible_if": "{{ block.settings.dotUI and block.settings.only_show_mobile == false and block.settings.box_layout == 'carousel' }}"
      },
    ],
    "presets": [
      {
        "name": "Product deals",
        "blocks": [
        {
          "type": "_deals_product",
          "static": true,
          "id": "product-deals-product",
          "settings": {
            "product": "{{ closest.product }}"
          }
        }
      ]
      }
    ]
  }
{% endschema %}
